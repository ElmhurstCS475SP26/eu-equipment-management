datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String        @id @default(cuid())
  clerkId      String        @unique
  name         String
  email        String        @unique
  role         String        @default("student") // student | staff | admin
  reservations Reservation[]
  checkouts    Checkout[]
  createdAt    DateTime      @default(now())
}

model Item {
  id            Int      @id @default(autoincrement())
  externalId    String?  @unique
  name          String
  barcode       String?  @unique
  category      String
  status        String   @default("available") // available | checked_out | flagged
  description   String?
  imageUrl      String?
  brand         String?
  model         String?
  location      String?
  quantity      Int?
  kind          String?
  cheqroomKitId String?
  kitId         Int?
  createdAt     DateTime @default(now())

  kit           Kit?           @relation(fields: [kitId], references: [id])
  reservations  Reservation[]
  checkouts     Checkout[]
  flags         Flag[]
}

model Kit {
  id         Int      @id @default(autoincrement())
  externalId String?  @unique
  name       String
  status     String   @default("available")
  items      Item[]
  createdAt  DateTime @default(now())
}

model Reservation {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  itemId    Int
  item      Item     @relation(fields: [itemId], references: [id])
  startDate DateTime
  endDate   DateTime
  status    String   @default("approved") // approved | cancelled | completed
  bookingId String?  // To group multiple items in one reservation
  studentId String?  // Student ID number for confirmation
  createdAt DateTime @default(now())
}

model Checkout {
  id             Int       @id @default(autoincrement())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  itemId         Int
  item           Item      @relation(fields: [itemId], references: [id])
  checkedOutAt   DateTime  @default(now())
  dueDate        DateTime
  returnedAt     DateTime?
  contractPdfUrl String?
}

model Flag {
  id        Int      @id @default(autoincrement())
  itemId    Int
  item      Item     @relation(fields: [itemId], references: [id])
  reason    String
  notes     String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}